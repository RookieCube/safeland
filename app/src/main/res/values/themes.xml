<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - Light -->
    <style name="Theme.SafeLand" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/telegram_green</item>
        <item name="android:colorPrimaryDark">@color/telegram_green_dark</item>
        <item name="android:colorAccent">@color/telegram_green_light</item>
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:statusBarColor">@color/telegram_green</item>
        <item name="android:navigationBarColor">@color/light_surface</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.SafeLand.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/telegram_green_light</item>
        <item name="android:colorPrimaryDark">@color/dark_surface</item>
        <item name="android:colorAccent">@color/telegram_green</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_surface</item>
        <item name="android:navigationBarColor">@color/dark_surface</item>
    </style>
</resources>
